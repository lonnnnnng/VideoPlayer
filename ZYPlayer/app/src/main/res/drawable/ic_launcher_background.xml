<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FF08111F"
                android:centerColor="#FF13345B"
                android:endColor="#FF00A3B8" />
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="28%"
                android:centerY="24%"
                android:gradientRadius="92dp"
                android:centerColor="#4D66F2FF"
                android:endColor="#0066F2FF" />
        </shape>
    </item>
    <item
        android:left="22dp"
        android:top="24dp"
        android:right="22dp"
        android:bottom="18dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="48dp"
                android:centerColor="#3DFF4F8B"
                android:endColor="#00FF4F8B" />
        </shape>
    </item>
    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="72%"
                android:centerY="78%"
                android:gradientRadius="76dp"
                android:centerColor="#2EFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
