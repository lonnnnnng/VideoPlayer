<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#FFEAF6FF"
                android:centerColor="#FFBFE4FF"
                android:endColor="#FF2F8CFF" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="24%"
                android:centerY="22%"
                android:gradientRadius="92dp"
                android:centerColor="#FFFFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    <item
        android:left="42dp"
        android:top="8dp"
        android:right="-8dp"
        android:bottom="42dp">
        <shape android:shape="oval">
            <solid android:color="#6639D5FF" />
        </shape>
    </item>
    <item
        android:left="-10dp"
        android:top="54dp"
        android:right="42dp"
        android:bottom="-8dp">
        <shape android:shape="oval">
            <solid android:color="#4D6BA9FF" />
        </shape>
    </item>
</layer-list>
